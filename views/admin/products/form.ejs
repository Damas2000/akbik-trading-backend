<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - <%= product ? 'Edit' : 'New' %> Product</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'categories' }) %>

  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
      <a href="/admin/categories" class="hover:text-blue-600">Categories</a>
      <span class="text-slate-300">/</span>
      <a href="/admin/categories/<%= category._id %>/products" class="hover:text-blue-600"><%= category.name %></a>
      <span class="text-slate-300">/</span>
      <span class="text-slate-800 font-semibold"><%= product ? 'Edit' : 'New' %></span>
    </div>
    <h1 class="text-2xl font-extrabold text-slate-800 mb-6"><%= product ? 'Edit' : 'New' %> Product</h1>

    <form method="POST" action="<%= product ? '/admin/products/' + product._id : '/admin/categories/' + category._id + '/products' %>" enctype="multipart/form-data" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Name *</label>
        <input name="name" type="text" required value="<%= product ? product.name : '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500 transition-all" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Description</label>
        <textarea name="description" rows="3" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500 transition-all"><%= product ? product.description : '' %></textarea>
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Price</label>
        <div class="relative w-40">
          <span class="absolute inset-y-0 left-0 flex items-center pl-4 text-slate-400 font-bold">$</span>
          <input name="price" type="number" step="0.01" value="<%= product ? product.price : 0 %>" class="w-full pl-8 pr-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500 transition-all" />
        </div>
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Image</label>
        <% if (product && product.image_url) { %>
          <img src="<%= product.image_url %>" class="w-32 h-32 object-cover rounded-xl mb-3 shadow-sm" />
        <% } %>
        <input name="image" type="file" accept="image/*" class="w-full text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-violet-50 file:text-violet-700 hover:file:bg-violet-100" />
        <% if (!product) { %>
          <p class="text-xs text-slate-400 mt-2">Or provide URL below</p>
          <input name="image_url" type="text" placeholder="https://..." class="w-full px-4 py-3 border border-slate-200 rounded-xl mt-2 focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500 transition-all" />
        <% } %>
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Sort Order</label>
        <input name="sort_order" type="number" value="<%= product ? product.sort_order : 0 %>" class="w-32 px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-violet-500/20 focus:border-violet-500 transition-all" />
      </div>
      <div class="flex gap-3 pt-4 border-t border-slate-100">
        <button type="submit" class="bg-gradient-to-r from-violet-500 to-violet-600 text-white px-8 py-3 rounded-xl hover:from-violet-600 hover:to-violet-700 font-semibold shadow-lg shadow-violet-500/25 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">save</span> Save
        </button>
        <a href="/admin/categories/<%= category._id %>/products" class="px-8 py-3 rounded-xl border border-slate-200 text-slate-600 hover:bg-slate-50 font-medium transition-all">Cancel</a>
      </div>
    </form>
  </div>
  <%
    var tourSteps = [
      { popover: { title: product ? 'Edit Product' : 'New Product', description: product ? 'Update this product information.' : 'Add a new product to the "' + category.name + '" category.' } },
      { element: 'form > div:first-child', popover: { title: 'Product Name', description: 'The product name as customers will see it. Be descriptive but concise.' } },
      { element: 'form > div:nth-child(2)', popover: { title: 'Description', description: 'A detailed description of the product. Mention key features, specifications, and benefits.' } },
      { element: 'form > div:nth-child(3)', popover: { title: 'Price', description: 'Set the product price in USD. Use decimal for cents (e.g. 29.99).' } },
      { element: 'form > div:nth-child(4)', popover: { title: 'Product Image', description: 'Upload a clear product photo. White background images work best. You can also paste a URL.' } }
    ];
    var tourKey = 'product-form';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
