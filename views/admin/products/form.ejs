<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Akbik Admin - <%= product ? 'Edit' : 'New' %> Product</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('../partials/nav', { current: 'categories' }) %>

  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="flex items-center gap-2 text-sm text-gray-500 mb-4">
      <a href="/admin/categories" class="hover:text-blue-600">Categories</a>
      <span>/</span>
      <a href="/admin/categories/<%= category._id %>/products" class="hover:text-blue-600"><%= category.name %></a>
      <span>/</span>
      <span class="text-gray-800 font-medium"><%= product ? 'Edit' : 'New' %></span>
    </div>
    <h1 class="text-2xl font-bold text-gray-800 mb-6"><%= product ? 'Edit' : 'New' %> Product</h1>

    <form method="POST" action="<%= product ? '/admin/products/' + product._id : '/admin/categories/' + category._id + '/products' %>" enctype="multipart/form-data" class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
        <input name="name" type="text" required value="<%= product ? product.name : '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
        <textarea name="description" rows="3" class="w-full px-3 py-2 border border-gray-300 rounded-lg"><%= product ? product.description : '' %></textarea>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Price</label>
        <input name="price" type="number" step="0.01" value="<%= product ? product.price : 0 %>" class="w-40 px-3 py-2 border border-gray-300 rounded-lg" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Image</label>
        <% if (product && product.image_url) { %>
          <img src="<%= product.image_url %>" class="w-32 h-32 object-cover rounded mb-2" />
        <% } %>
        <input name="image" type="file" accept="image/*" class="w-full text-sm" />
        <% if (!product) { %>
          <p class="text-xs text-gray-400 mt-1">Or provide URL below</p>
          <input name="image_url" type="text" placeholder="https://..." class="w-full px-3 py-2 border border-gray-300 rounded-lg mt-1" />
        <% } %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Sort Order</label>
        <input name="sort_order" type="number" value="<%= product ? product.sort_order : 0 %>" class="w-32 px-3 py-2 border border-gray-300 rounded-lg" />
      </div>
      <div class="flex gap-3 pt-4">
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 font-medium">Save</button>
        <a href="/admin/categories/<%= category._id %>/products" class="px-6 py-2 rounded-lg border text-gray-600 hover:bg-gray-50">Cancel</a>
      </div>
    </form>
  </div>
</body>
</html>
