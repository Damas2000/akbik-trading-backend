<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Products: <%= category.name %></title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'categories' }) %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex items-center gap-2 text-sm text-slate-500 mb-4">
      <a href="/admin/categories" class="hover:text-blue-600 flex items-center gap-1"><span class="material-symbols-outlined text-base">arrow_back</span> Categories</a>
      <span class="text-slate-300">/</span>
      <span class="text-slate-800 font-semibold"><%= category.name %></span>
    </div>
    <div id="page-header" class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-extrabold text-slate-800">Products in "<%= category.name %>"</h1>
      <a id="add-btn" href="/admin/categories/<%= category._id %>/products/new" class="flex items-center gap-2 bg-gradient-to-r from-violet-500 to-violet-600 text-white px-5 py-2.5 rounded-xl hover:from-violet-600 hover:to-violet-700 text-sm font-semibold shadow-lg shadow-violet-500/25 transition-all">
        <span class="material-symbols-outlined text-lg">add</span> New Product
      </a>
    </div>

    <div id="products-table" class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
      <table class="w-full">
        <thead class="bg-gradient-to-r from-slate-50 to-slate-100 border-b border-slate-200">
          <tr>
            <th class="text-left px-5 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Image</th>
            <th class="text-left px-5 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Name</th>
            <th class="text-left px-5 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Price</th>
            <th class="text-left px-5 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Order</th>
            <th class="text-right px-5 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(function(p) { %>
          <tr class="border-b border-slate-100 hover:bg-violet-50/50 transition-colors">
            <td class="px-5 py-4">
              <% if (p.image_url) { %>
                <img src="<%= p.image_url %>" class="w-16 h-16 object-cover rounded-xl shadow-sm" />
              <% } else { %>
                <div class="w-16 h-16 bg-slate-200 rounded-xl flex items-center justify-center text-slate-400 text-xs">No img</div>
              <% } %>
            </td>
            <td class="px-5 py-4 text-sm font-bold text-slate-800"><%= p.name %></td>
            <td class="px-5 py-4"><span class="text-sm font-bold text-emerald-600 bg-emerald-50 px-3 py-1 rounded-lg">$<%= p.price.toFixed(2) %></span></td>
            <td class="px-5 py-4"><span class="text-sm text-slate-500 bg-slate-100 px-2.5 py-1 rounded-lg font-mono"><%= p.sort_order %></span></td>
            <td class="px-5 py-4 text-right">
              <a href="/admin/products/<%= p._id %>/edit" class="inline-flex items-center gap-1 text-blue-600 hover:text-blue-700 text-sm font-medium mr-3">
                <span class="material-symbols-outlined text-base">edit</span> Edit
              </a>
              <form method="POST" action="/admin/products/<%= p._id %>/delete" class="inline" onsubmit="return confirm('Delete this product?')">
                <button type="submit" class="inline-flex items-center gap-1 text-red-500 hover:text-red-700 text-sm font-medium">
                  <span class="material-symbols-outlined text-base">delete</span> Delete
                </button>
              </form>
            </td>
          </tr>
          <% }); %>
          <% if (products.length === 0) { %>
          <tr><td colspan="5" class="px-5 py-12 text-center text-slate-400">
            <span class="material-symbols-outlined text-5xl mb-2 text-slate-300">inventory_2</span>
            <p class="font-medium">No products yet</p>
          </td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
  <%
    var tourSteps = [
      { element: '#page-header', popover: { title: 'Products', description: 'These are the products inside this category. Products appear on the homepage under their category.' } },
      { element: '#add-btn', popover: { title: 'Add Product', description: 'Create a new product with name, price, image, and description.' } },
      { element: '#products-table', popover: { title: 'Product List', description: 'All products in this category. Edit prices, images, or delete items from here.' } },
      { popover: { title: 'Tips', description: 'Use clear product images on white backgrounds. Set accurate prices. The order number determines display position in the category.' } }
    ];
    var tourKey = 'products';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
