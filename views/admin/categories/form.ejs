<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - <%= category ? 'Edit' : 'New' %> Category</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'categories' }) %>

  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="mb-6">
      <a href="/admin/categories" class="text-sm text-slate-500 hover:text-emerald-600 flex items-center gap-1 mb-2">
        <span class="material-symbols-outlined text-base">arrow_back</span> Back to Categories
      </a>
      <h1 class="text-2xl font-extrabold text-slate-800"><%= category ? 'Edit' : 'New' %> Category</h1>
    </div>

    <form method="POST" action="<%= category ? '/admin/categories/' + category._id : '/admin/categories' %>" enctype="multipart/form-data" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Name *</label>
        <input name="name" type="text" required value="<%= category ? category.name : '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" />
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Image</label>
        <% if (category && category.image_url) { %>
          <img src="<%= category.image_url %>" class="w-32 h-32 object-cover rounded-xl mb-3 shadow-sm" />
        <% } %>
        <input name="image" type="file" accept="image/*" class="w-full text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-emerald-50 file:text-emerald-700 hover:file:bg-emerald-100" />
        <% if (!category) { %>
          <p class="text-xs text-slate-400 mt-2">Or provide URL below</p>
          <input name="image_url" type="text" placeholder="https://..." class="w-full px-4 py-3 border border-slate-200 rounded-xl mt-2 focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" />
        <% } %>
      </div>
      <div>
        <label class="block text-sm font-bold text-slate-700 mb-2">Sort Order</label>
        <input name="sort_order" type="number" value="<%= category ? category.sort_order : 0 %>" class="w-32 px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" />
      </div>
      <div class="flex gap-3 pt-4 border-t border-slate-100">
        <button type="submit" class="bg-gradient-to-r from-emerald-500 to-emerald-600 text-white px-8 py-3 rounded-xl hover:from-emerald-600 hover:to-emerald-700 font-semibold shadow-lg shadow-emerald-500/25 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">save</span> Save
        </button>
        <a href="/admin/categories" class="px-8 py-3 rounded-xl border border-slate-200 text-slate-600 hover:bg-slate-50 font-medium transition-all">Cancel</a>
      </div>
    </form>
  </div>
  <%
    var tourSteps = [
      { popover: { title: category ? 'Edit Category' : 'New Category', description: category ? 'Update this category details.' : 'Create a new product category to organize your products.' } },
      { element: 'form > div:first-child', popover: { title: 'Category Name', description: 'A short, descriptive name (e.g. "Power Tools", "Plumbing"). This appears on the homepage category slider.' } },
      { element: 'form > div:nth-child(2)', popover: { title: 'Category Image', description: 'Upload a representative image for this category. Square format (500x500) works best.' } },
      { element: 'form > div:nth-child(3)', popover: { title: 'Sort Order', description: 'Controls display position. Categories with lower numbers appear first in the slider.' } }
    ];
    var tourKey = 'category-form';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
