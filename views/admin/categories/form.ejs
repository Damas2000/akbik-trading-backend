<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Akbik Admin - <%= category ? 'Edit' : 'New' %> Category</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('../partials/nav', { current: 'categories' }) %>

  <div class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold text-gray-800 mb-6"><%= category ? 'Edit' : 'New' %> Category</h1>

    <form method="POST" action="<%= category ? '/admin/categories/' + category._id : '/admin/categories' %>" enctype="multipart/form-data" class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Name *</label>
        <input name="name" type="text" required value="<%= category ? category.name : '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Image</label>
        <% if (category && category.image_url) { %>
          <img src="<%= category.image_url %>" class="w-32 h-32 object-cover rounded mb-2" />
        <% } %>
        <input name="image" type="file" accept="image/*" class="w-full text-sm" />
        <% if (!category) { %>
          <p class="text-xs text-gray-400 mt-1">Or provide URL below</p>
          <input name="image_url" type="text" placeholder="https://..." class="w-full px-3 py-2 border border-gray-300 rounded-lg mt-1" />
        <% } %>
      </div>
      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Sort Order</label>
        <input name="sort_order" type="number" value="<%= category ? category.sort_order : 0 %>" class="w-32 px-3 py-2 border border-gray-300 rounded-lg" />
      </div>
      <div class="flex gap-3 pt-4">
        <button type="submit" class="bg-blue-600 text-white px-6 py-2 rounded-lg hover:bg-blue-700 font-medium">Save</button>
        <a href="/admin/categories" class="px-6 py-2 rounded-lg border text-gray-600 hover:bg-gray-50">Cancel</a>
      </div>
    </form>
  </div>
</body>
</html>
