<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - About Page</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'about' }) %>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-slate-800">About Page</h1>
      <p class="text-slate-500 text-sm mt-1">Edit your About Us page content</p>
    </div>

    <form method="POST" action="/admin/about" enctype="multipart/form-data" class="space-y-6">
      <!-- Hero Section -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-blue-500">image</span> Hero Section
        </h2>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Hero Image</label>
          <% if (page.hero_image_url) { %><img src="<%= page.hero_image_url %>" class="w-40 h-24 object-cover rounded-xl mb-3 shadow-sm" /><% } %>
          <input name="hero_image" type="file" accept="image/*" class="w-full text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-blue-50 file:text-blue-700 hover:file:bg-blue-100" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Badge Text</label>
            <input name="hero_badge" type="text" value="<%= page.hero_badge || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Title</label>
            <input name="hero_title" type="text" value="<%= page.hero_title || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Description</label>
          <textarea name="hero_description" rows="2" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all"><%= page.hero_description || '' %></textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Button 1 Text</label>
            <input name="hero_button1_text" type="text" value="<%= page.hero_button1_text || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Button 1 URL</label>
            <input name="hero_button1_url" type="text" value="<%= page.hero_button1_url || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Button 2 Text</label>
            <input name="hero_button2_text" type="text" value="<%= page.hero_button2_text || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Button 2 URL</label>
            <input name="hero_button2_url" type="text" value="<%= page.hero_button2_url || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" />
          </div>
        </div>
      </div>

      <!-- Story Section -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-amber-500">auto_stories</span> Our Story
        </h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Subtitle</label>
            <input name="story_subtitle" type="text" value="<%= page.story_subtitle || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Title</label>
            <input name="story_title" type="text" value="<%= page.story_title || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Paragraphs <span class="text-slate-400 font-normal">(separate with ---)</span></label>
          <textarea name="story_paragraphs" rows="8" class="w-full px-4 py-3 border border-slate-200 rounded-xl font-mono text-sm focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all"><%= (page.story_paragraphs || []).join('\n---\n') %></textarea>
        </div>
      </div>

      <!-- Info Cards -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-emerald-500">widgets</span> Info Cards
        </h2>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Card 1 Icon</label>
            <input name="card1_icon" type="text" value="<%= page.card1_icon || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" placeholder="e.g. verified" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Card 1 Title</label>
            <input name="card1_title" type="text" value="<%= page.card1_title || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Card 1 Description</label>
            <input name="card1_description" type="text" value="<%= page.card1_description || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" />
          </div>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Card 2 Icon</label>
            <input name="card2_icon" type="text" value="<%= page.card2_icon || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" placeholder="e.g. groups" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Card 2 Title</label>
            <input name="card2_title" type="text" value="<%= page.card2_title || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Card 2 Description</label>
            <input name="card2_description" type="text" value="<%= page.card2_description || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" />
          </div>
        </div>
      </div>

      <!-- Images -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-pink-500">collections</span> Images
        </h2>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Image 1 (Large)</label>
            <% if (page.image1_url) { %><img src="<%= page.image1_url %>" class="w-full h-20 object-cover rounded-xl mb-2 shadow-sm" /><% } %>
            <input name="image1" type="file" accept="image/*" class="w-full text-xs file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-pink-50 file:text-pink-700" />
            <input name="image1_caption" type="text" value="<%= page.image1_caption || '' %>" placeholder="Caption" class="w-full px-3 py-2 border border-slate-200 rounded-lg text-sm mt-2 focus:ring-2 focus:ring-pink-500/20 focus:border-pink-500" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Image 2</label>
            <% if (page.image2_url) { %><img src="<%= page.image2_url %>" class="w-full h-20 object-cover rounded-xl mb-2 shadow-sm" /><% } %>
            <input name="image2" type="file" accept="image/*" class="w-full text-xs file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-pink-50 file:text-pink-700" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Image 3</label>
            <% if (page.image3_url) { %><img src="<%= page.image3_url %>" class="w-full h-20 object-cover rounded-xl mb-2 shadow-sm" /><% } %>
            <input name="image3" type="file" accept="image/*" class="w-full text-xs file:mr-2 file:py-1.5 file:px-3 file:rounded-lg file:border-0 file:text-xs file:font-semibold file:bg-pink-50 file:text-pink-700" />
          </div>
        </div>
      </div>

      <!-- CTA Box -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-orange-500">campaign</span> CTA Box
        </h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Title</label>
            <input name="cta_title" type="text" value="<%= page.cta_title || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Description</label>
            <input name="cta_description" type="text" value="<%= page.cta_description || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Link Text</label>
            <input name="cta_link_text" type="text" value="<%= page.cta_link_text || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Link URL</label>
            <input name="cta_link_url" type="text" value="<%= page.cta_link_url || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-all" />
          </div>
        </div>
      </div>

      <!-- Visit Us -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-teal-500">storefront</span> Visit Us Section
        </h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Title</label>
            <input name="visit_title" type="text" value="<%= page.visit_title || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500/20 focus:border-teal-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Description</label>
            <input name="visit_description" type="text" value="<%= page.visit_description || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500/20 focus:border-teal-500 transition-all" />
          </div>
        </div>
      </div>

      <button type="submit" class="bg-gradient-to-r from-indigo-500 to-purple-600 text-white px-8 py-3 rounded-xl hover:from-indigo-600 hover:to-purple-700 font-semibold shadow-lg shadow-indigo-500/25 transition-all flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">save</span> Save About Page
      </button>
    </form>
  </div>
  <%
    var tourSteps = [
      { popover: { title: 'About Page Editor', description: 'This page lets you fully customize your About Us page. It has multiple sections - scroll down to edit each one.' } },
      { element: 'form .space-y-6 > div:first-child', popover: { title: 'Hero Section', description: 'The top banner of your About page. Upload a hero image, set badge text (e.g. "Since 1954"), title, description, and two action buttons.' } },
      { element: 'form .space-y-6 > div:nth-child(2)', popover: { title: 'Our Story', description: 'Tell your company story. Use "---" to separate paragraphs. The subtitle and title appear above the story text.' } },
      { element: 'form .space-y-6 > div:nth-child(3)', popover: { title: 'Info Cards', description: 'Two highlight cards that appear alongside your story. Set an icon (Material Symbol name), title, and description for each.' } },
      { element: 'form .space-y-6 > div:nth-child(4)', popover: { title: 'Image Gallery', description: 'Upload up to 3 images. Image 1 is the large featured image. The caption appears overlaid on Image 1.' } },
      { element: 'form .space-y-6 > div:nth-child(5)', popover: { title: 'CTA Box', description: 'A call-to-action box that appears after the story section. Set a title, description, and a link to guide visitors.' } },
      { popover: { title: 'Tips', description: 'Tell an authentic story. Use real photos of your team/store. Keep the CTA relevant - link to your contact page or a key service.' } }
    ];
    var tourKey = 'about';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
