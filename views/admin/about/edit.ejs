<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Akbik Admin - About Page</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('../partials/nav', { current: 'about' }) %>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">About Page</h1>

    <form method="POST" action="/admin/about" enctype="multipart/form-data" class="space-y-8">
      <!-- Hero Section -->
      <div class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
        <h2 class="text-lg font-bold text-gray-700 border-b pb-2">Hero Section</h2>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Hero Image</label>
          <% if (page.hero_image_url) { %><img src="<%= page.hero_image_url %>" class="w-40 h-24 object-cover rounded mb-2" /><% } %>
          <input name="hero_image" type="file" accept="image/*" class="w-full text-sm" />
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Badge Text</label>
            <input name="hero_badge" type="text" value="<%= page.hero_badge || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
            <input name="hero_title" type="text" value="<%= page.hero_title || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
          <textarea name="hero_description" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg"><%= page.hero_description || '' %></textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Button 1 Text</label>
            <input name="hero_button1_text" type="text" value="<%= page.hero_button1_text || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Button 1 URL</label>
            <input name="hero_button1_url" type="text" value="<%= page.hero_button1_url || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Button 2 Text</label>
            <input name="hero_button2_text" type="text" value="<%= page.hero_button2_text || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Button 2 URL</label>
            <input name="hero_button2_url" type="text" value="<%= page.hero_button2_url || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
        </div>
      </div>

      <!-- Story Section -->
      <div class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
        <h2 class="text-lg font-bold text-gray-700 border-b pb-2">Our Story</h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Subtitle</label>
            <input name="story_subtitle" type="text" value="<%= page.story_subtitle || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
            <input name="story_title" type="text" value="<%= page.story_title || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Paragraphs (separate with ---)</label>
          <textarea name="story_paragraphs" rows="8" class="w-full px-3 py-2 border border-gray-300 rounded-lg font-mono text-sm"><%= (page.story_paragraphs || []).join('\n---\n') %></textarea>
        </div>
      </div>

      <!-- Info Cards -->
      <div class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
        <h2 class="text-lg font-bold text-gray-700 border-b pb-2">Info Cards</h2>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Card 1 Icon</label>
            <input name="card1_icon" type="text" value="<%= page.card1_icon || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="e.g. verified" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Card 1 Title</label>
            <input name="card1_title" type="text" value="<%= page.card1_title || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Card 1 Description</label>
            <input name="card1_description" type="text" value="<%= page.card1_description || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
        </div>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Card 2 Icon</label>
            <input name="card2_icon" type="text" value="<%= page.card2_icon || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="e.g. groups" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Card 2 Title</label>
            <input name="card2_title" type="text" value="<%= page.card2_title || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Card 2 Description</label>
            <input name="card2_description" type="text" value="<%= page.card2_description || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
        </div>
      </div>

      <!-- Images -->
      <div class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
        <h2 class="text-lg font-bold text-gray-700 border-b pb-2">Images</h2>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Image 1 (Large)</label>
            <% if (page.image1_url) { %><img src="<%= page.image1_url %>" class="w-full h-20 object-cover rounded mb-1" /><% } %>
            <input name="image1" type="file" accept="image/*" class="w-full text-xs" />
            <input name="image1_caption" type="text" value="<%= page.image1_caption || '' %>" placeholder="Caption" class="w-full px-2 py-1 border border-gray-300 rounded text-sm mt-1" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Image 2</label>
            <% if (page.image2_url) { %><img src="<%= page.image2_url %>" class="w-full h-20 object-cover rounded mb-1" /><% } %>
            <input name="image2" type="file" accept="image/*" class="w-full text-xs" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Image 3</label>
            <% if (page.image3_url) { %><img src="<%= page.image3_url %>" class="w-full h-20 object-cover rounded mb-1" /><% } %>
            <input name="image3" type="file" accept="image/*" class="w-full text-xs" />
          </div>
        </div>
      </div>

      <!-- CTA Box -->
      <div class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
        <h2 class="text-lg font-bold text-gray-700 border-b pb-2">CTA Box</h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
            <input name="cta_title" type="text" value="<%= page.cta_title || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            <input name="cta_description" type="text" value="<%= page.cta_description || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Link Text</label>
            <input name="cta_link_text" type="text" value="<%= page.cta_link_text || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Link URL</label>
            <input name="cta_link_url" type="text" value="<%= page.cta_link_url || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
        </div>
      </div>

      <!-- Visit Us -->
      <div class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
        <h2 class="text-lg font-bold text-gray-700 border-b pb-2">Visit Us Section</h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Title</label>
            <input name="visit_title" type="text" value="<%= page.visit_title || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
            <input name="visit_description" type="text" value="<%= page.visit_description || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
          </div>
        </div>
      </div>

      <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-lg hover:bg-blue-700 font-medium">Save About Page</button>
    </form>
  </div>
</body>
</html>
