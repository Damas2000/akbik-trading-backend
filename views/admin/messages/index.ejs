<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Messages</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'messages' }) %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div id="page-header" class="flex items-center justify-between mb-6">
      <div class="flex items-center gap-3">
        <h1 class="text-2xl font-extrabold text-slate-800">Contact Messages</h1>
        <% if (unreadCount > 0) { %>
          <span class="bg-gradient-to-r from-rose-500 to-rose-600 text-white text-xs px-3 py-1 rounded-full font-bold shadow-lg shadow-rose-500/25"><%= unreadCount %> new</span>
        <% } %>
      </div>
    </div>

    <div id="messages-list" class="space-y-4">
      <% if (messages.length === 0) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-16 text-center">
          <span class="material-symbols-outlined text-6xl mb-3 text-slate-300">inbox</span>
          <p class="text-slate-500 font-medium">No messages yet</p>
        </div>
      <% } %>
      <% messages.forEach(function(msg) { %>
        <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 <%= !msg.is_read ? 'border-l-4 border-l-blue-500 bg-blue-50/30' : '' %> hover:shadow-md transition-all">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <div class="w-10 h-10 bg-gradient-to-br from-slate-600 to-slate-700 rounded-xl flex items-center justify-center text-white font-bold text-sm">
                  <%= msg.first_name ? msg.first_name[0].toUpperCase() : '?' %><%= msg.last_name ? msg.last_name[0].toUpperCase() : '' %>
                </div>
                <div>
                  <span class="font-bold text-slate-800"><%= msg.first_name %> <%= msg.last_name %></span>
                  <span class="text-sm text-slate-400 ml-2">&lt;<%= msg.email %>&gt;</span>
                </div>
                <% if (!msg.is_read) { %>
                  <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded-full font-bold">New</span>
                <% } %>
              </div>
              <div class="text-sm text-slate-500 mb-2 pl-[52px]">
                <span class="font-semibold text-slate-700"><%= msg.subject %></span>
                <span class="mx-2 text-slate-300">|</span>
                <span><%= new Date(msg.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
              </div>
              <p class="text-slate-700 whitespace-pre-wrap pl-[52px]"><%= msg.message %></p>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <% if (!msg.is_read) { %>
                <form method="POST" action="/admin/messages/<%= msg._id %>/read" class="inline">
                  <button type="submit" class="w-9 h-9 bg-blue-50 hover:bg-blue-100 text-blue-600 rounded-xl flex items-center justify-center transition-colors" title="Mark as read">
                    <span class="material-symbols-outlined text-lg">mark_email_read</span>
                  </button>
                </form>
              <% } %>
              <form method="POST" action="/admin/messages/<%= msg._id %>/delete" class="inline" onsubmit="return confirm('Delete this message?')">
                <button type="submit" class="w-9 h-9 bg-red-50 hover:bg-red-100 text-red-500 rounded-xl flex items-center justify-center transition-colors" title="Delete">
                  <span class="material-symbols-outlined text-lg">delete</span>
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
  <%
    var tourSteps = [
      { element: '#page-header', popover: { title: 'Contact Messages', description: 'All messages submitted through your Contact Us form appear here. The badge shows how many are unread.' } },
      { element: '#messages-list', popover: { title: 'Message List', description: 'Unread messages have a blue left border. Click the checkmark to mark as read, or the trash icon to delete.' } },
      { popover: { title: 'Tips', description: 'Check messages regularly. Unread count also appears on the Dashboard and in the navigation bar. Messages are also tracked as Leads for follow-up.' } }
    ];
    var tourKey = 'messages';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
