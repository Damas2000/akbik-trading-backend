<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Akbik Admin - Messages</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('../partials/nav', { current: 'messages' }) %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-800">
        Contact Messages
        <% if (unreadCount > 0) { %>
          <span class="ml-2 bg-red-500 text-white text-xs px-2 py-1 rounded-full"><%= unreadCount %> new</span>
        <% } %>
      </h1>
    </div>

    <div class="space-y-4">
      <% if (messages.length === 0) { %>
        <div class="bg-white rounded-xl shadow-sm border p-12 text-center text-gray-400">
          <span class="material-symbols-outlined text-5xl mb-2">inbox</span>
          <p>No messages yet</p>
        </div>
      <% } %>
      <% messages.forEach(function(msg) { %>
        <div class="bg-white rounded-xl shadow-sm border p-6 <%= !msg.is_read ? 'border-l-4 border-l-blue-500' : '' %>">
          <div class="flex items-start justify-between gap-4">
            <div class="flex-1">
              <div class="flex items-center gap-3 mb-2">
                <span class="font-bold text-gray-800"><%= msg.first_name %> <%= msg.last_name %></span>
                <span class="text-sm text-gray-400">&lt;<%= msg.email %>&gt;</span>
                <% if (!msg.is_read) { %>
                  <span class="bg-blue-100 text-blue-700 text-xs px-2 py-0.5 rounded font-medium">New</span>
                <% } %>
              </div>
              <div class="text-sm text-gray-500 mb-2">
                <span class="font-medium"><%= msg.subject %></span>
                &middot;
                <span><%= new Date(msg.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'short', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
              </div>
              <p class="text-gray-700 whitespace-pre-wrap"><%= msg.message %></p>
            </div>
            <div class="flex items-center gap-2 flex-shrink-0">
              <% if (!msg.is_read) { %>
                <form method="POST" action="/admin/messages/<%= msg._id %>/read" class="inline">
                  <button type="submit" class="text-blue-600 hover:text-blue-700 text-sm" title="Mark as read">
                    <span class="material-symbols-outlined text-xl">mark_email_read</span>
                  </button>
                </form>
              <% } %>
              <form method="POST" action="/admin/messages/<%= msg._id %>/delete" class="inline" onsubmit="return confirm('Delete this message?')">
                <button type="submit" class="text-red-500 hover:text-red-700 text-sm" title="Delete">
                  <span class="material-symbols-outlined text-xl">delete</span>
                </button>
              </form>
            </div>
          </div>
        </div>
      <% }); %>
    </div>
  </div>
</body>
</html>
