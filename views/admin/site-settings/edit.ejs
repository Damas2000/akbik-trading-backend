<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Site Settings</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'settings' }) %>

  <div class="max-w-4xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-slate-800">Site Settings</h1>
      <p class="text-slate-500 text-sm mt-1">Global site configuration</p>
    </div>

    <form action="/admin/site-settings" method="POST" enctype="multipart/form-data" class="space-y-6">
      <!-- General -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-amber-500">tune</span> General
        </h2>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Site Name</label>
          <input type="text" name="site_name" value="<%= settings.site_name || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all">
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Footer Text</label>
          <textarea name="footer_text" rows="2" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all"><%= settings.footer_text || '' %></textarea>
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">CTA Title</label>
          <input type="text" name="cta_title" value="<%= settings.cta_title || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" placeholder="e.g. Gear Up for Your Next Build">
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">CTA Description</label>
          <textarea name="cta_description" rows="2" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-amber-500/20 focus:border-amber-500 transition-all" placeholder="e.g. Join our PRO-Access newsletter..."><%= settings.cta_description || '' %></textarea>
        </div>
      </div>

      <!-- Images -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-pink-500">image</span> Logo & Favicon
        </h2>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Logo</label>
          <% if (settings.logo_url) { %>
            <img src="<%= settings.logo_url %>" alt="Logo" class="w-24 h-24 object-contain mb-3 bg-slate-100 rounded-xl p-2">
          <% } %>
          <input type="file" name="logo" accept="image/*" class="text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100">
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Favicon</label>
          <% if (settings.favicon_url) { %>
            <img src="<%= settings.favicon_url %>" alt="Favicon" class="w-10 h-10 object-contain mb-3 bg-slate-100 rounded-xl p-1">
          <% } %>
          <input type="file" name="favicon" accept="image/*" class="text-sm file:mr-4 file:py-2 file:px-4 file:rounded-xl file:border-0 file:text-sm file:font-semibold file:bg-pink-50 file:text-pink-700 hover:file:bg-pink-100">
        </div>
      </div>

      <!-- SEO -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-emerald-500">search</span> SEO / Meta
        </h2>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Meta Title</label>
          <input type="text" name="meta_title" value="<%= settings.meta_title || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all">
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Meta Description</label>
          <textarea name="meta_description" rows="2" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all"><%= settings.meta_description || '' %></textarea>
        </div>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Meta Keywords</label>
          <input type="text" name="meta_keywords" value="<%= settings.meta_keywords || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" placeholder="comma, separated, keywords">
        </div>
      </div>

      <!-- Social Links -->
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-blue-500">share</span> Social Links
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Facebook</label>
            <input type="url" name="social_facebook" value="<%= settings.social_facebook || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="https://facebook.com/...">
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Instagram</label>
            <input type="url" name="social_instagram" value="<%= settings.social_instagram || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="https://instagram.com/...">
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Twitter / X</label>
            <input type="url" name="social_twitter" value="<%= settings.social_twitter || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="https://x.com/...">
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">LinkedIn</label>
            <input type="url" name="social_linkedin" value="<%= settings.social_linkedin || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="https://linkedin.com/...">
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">YouTube</label>
            <input type="url" name="social_youtube" value="<%= settings.social_youtube || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="https://youtube.com/...">
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">WhatsApp</label>
            <input type="url" name="social_whatsapp" value="<%= settings.social_whatsapp || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="https://wa.me/...">
          </div>
        </div>
      </div>

      <div id="save-section" class="flex gap-4">
        <button type="submit" class="bg-gradient-to-r from-slate-700 to-slate-800 text-white px-8 py-3 rounded-xl hover:from-slate-800 hover:to-slate-900 font-semibold shadow-lg shadow-slate-500/25 transition-all flex items-center gap-2">
          <span class="material-symbols-outlined text-lg">save</span> Save Settings
        </button>
        <a href="/admin" class="px-8 py-3 border border-slate-200 rounded-xl text-slate-600 hover:bg-slate-50 font-medium transition-all">Cancel</a>
      </div>
    </form>
  </div>
  <%
    var tourSteps = [
      { popover: { title: 'Site Settings', description: 'Global configuration for your entire website. Changes here affect the header, footer, SEO, and social links across all pages.' } },
      { element: 'form .space-y-6 > div:first-child', popover: { title: 'General Settings', description: 'Set your site name (appears in the header), footer text, and the CTA (Call to Action) section title and description shown on the homepage.' } },
      { element: 'form .space-y-6 > div:nth-child(2)', popover: { title: 'Logo & Favicon', description: 'Upload your brand logo (appears in header) and favicon (the small icon in browser tabs). PNG with transparency works best.' } },
      { element: 'form .space-y-6 > div:nth-child(3)', popover: { title: 'SEO / Meta Tags', description: 'Control how your site appears in Google search results. Set the meta title, description, and keywords for better search ranking.' } },
      { element: 'form .space-y-6 > div:nth-child(4)', popover: { title: 'Social Media Links', description: 'Add your social media profile URLs. These appear as icons in the website footer. Leave empty to hide a platform.' } },
      { popover: { title: 'Tips', description: 'Keep your meta description under 160 characters. Use a square logo (minimum 200x200px). Update social links whenever you create new profiles.' } }
    ];
    var tourKey = 'site-settings';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
