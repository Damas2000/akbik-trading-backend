<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Contact Info</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'contact' }) %>

  <div class="max-w-3xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-slate-800">Contact Information</h1>
      <p class="text-slate-500 text-sm mt-1">Edit contact page details</p>
    </div>

    <form method="POST" action="/admin/contact" class="space-y-6">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-teal-500">description</span> Page Header
        </h2>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Page Title</label>
            <input name="page_title" type="text" value="<%= info.page_title || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500/20 focus:border-teal-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Page Description</label>
            <input name="page_description" type="text" value="<%= info.page_description || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-teal-500/20 focus:border-teal-500 transition-all" />
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-blue-500">map</span> Google Maps
        </h2>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Embed URL</label>
          <input name="google_maps_url" type="text" value="<%= info.google_maps_url || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500 transition-all" placeholder="https://www.google.com/maps/embed?pb=..." />
          <p class="text-xs text-slate-400 mt-2 flex items-center gap-1">
            <span class="material-symbols-outlined text-sm">info</span>
            Google Maps > Share > Embed a map > Copy the src URL
          </p>
          <% if (info.google_maps_url) { %>
            <iframe src="<%= info.google_maps_url %>" class="w-full h-48 rounded-xl mt-3 border border-slate-200" loading="lazy" allowfullscreen></iframe>
          <% } %>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-emerald-500">contact_phone</span> Contact Details
        </h2>
        <div>
          <label class="block text-sm font-bold text-slate-700 mb-2">Address</label>
          <textarea name="address" rows="2" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all"><%= info.address || '' %></textarea>
        </div>
        <div class="grid grid-cols-2 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Phone</label>
            <input name="phone" type="text" value="<%= info.phone || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Email</label>
            <input name="email" type="text" value="<%= info.email || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-emerald-500/20 focus:border-emerald-500 transition-all" />
          </div>
        </div>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 space-y-5">
        <h2 class="text-lg font-bold text-slate-800 flex items-center gap-2 pb-3 border-b border-slate-100">
          <span class="material-symbols-outlined text-orange-500">schedule</span> Store Hours
        </h2>
        <div class="grid grid-cols-3 gap-4">
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Mon - Fri</label>
            <input name="hours_weekday" type="text" value="<%= info.hours_weekday || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-all" placeholder="7:00 AM - 8:00 PM" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Saturday</label>
            <input name="hours_saturday" type="text" value="<%= info.hours_saturday || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-all" placeholder="8:00 AM - 6:00 PM" />
          </div>
          <div>
            <label class="block text-sm font-bold text-slate-700 mb-2">Sunday</label>
            <input name="hours_sunday" type="text" value="<%= info.hours_sunday || '' %>" class="w-full px-4 py-3 border border-slate-200 rounded-xl focus:ring-2 focus:ring-orange-500/20 focus:border-orange-500 transition-all" placeholder="9:00 AM - 4:00 PM" />
          </div>
        </div>
      </div>

      <button type="submit" class="bg-gradient-to-r from-teal-500 to-emerald-600 text-white px-8 py-3 rounded-xl hover:from-teal-600 hover:to-emerald-700 font-semibold shadow-lg shadow-teal-500/25 transition-all flex items-center gap-2">
        <span class="material-symbols-outlined text-lg">save</span> Save Contact Info
      </button>
    </form>
  </div>
  <%
    var tourSteps = [
      { popover: { title: 'Contact Information', description: 'Configure everything shown on your Contact Us page - page header, map, contact details, and store hours.' } },
      { element: 'form .space-y-6 > div:first-child', popover: { title: 'Page Header', description: 'Set the main title and description text that appears at the top of your Contact page.' } },
      { element: 'form .space-y-6 > div:nth-child(2)', popover: { title: 'Google Maps', description: 'Paste your Google Maps embed URL. Go to Google Maps > Share > Embed a map > copy the "src" URL from the iframe code.' } },
      { element: 'form .space-y-6 > div:nth-child(3)', popover: { title: 'Contact Details', description: 'Your physical address, phone number, and email. These appear as info cards on the Contact page.' } },
      { element: 'form .space-y-6 > div:nth-child(4)', popover: { title: 'Store Hours', description: 'Set your business hours for weekdays, Saturday, and Sunday. These are displayed on the Contact page.' } },
      { popover: { title: 'Tips', description: 'Keep your contact details up-to-date. The map helps customers find your physical location easily.' } }
    ];
    var tourKey = 'contact';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
