<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Akbik Admin - Contact Info</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('../partials/nav', { current: 'contact' }) %>

  <div class="max-w-3xl mx-auto px-4 py-8">
    <h1 class="text-2xl font-bold text-gray-800 mb-6">Contact Information</h1>

    <form method="POST" action="/admin/contact" class="bg-white rounded-xl shadow-sm border p-6 space-y-4">
      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Page Title</label>
          <input name="page_title" type="text" value="<%= info.page_title || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Page Description</label>
          <input name="page_description" type="text" value="<%= info.page_description || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
        </div>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Google Maps Embed URL</label>
        <input name="google_maps_url" type="text" value="<%= info.google_maps_url || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="https://www.google.com/maps/embed?pb=..." />
        <p class="text-xs text-gray-400 mt-1">Google Maps &gt; Share &gt; Embed a map &gt; Copy the src URL from the iframe</p>
        <% if (info.google_maps_url) { %>
          <iframe src="<%= info.google_maps_url %>" class="w-full h-48 rounded-lg mt-2 border" loading="lazy" allowfullscreen></iframe>
        <% } %>
      </div>

      <div>
        <label class="block text-sm font-medium text-gray-700 mb-1">Address</label>
        <textarea name="address" rows="2" class="w-full px-3 py-2 border border-gray-300 rounded-lg"><%= info.address || '' %></textarea>
      </div>

      <div class="grid grid-cols-2 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Phone</label>
          <input name="phone" type="text" value="<%= info.phone || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Email</label>
          <input name="email" type="text" value="<%= info.email || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" />
        </div>
      </div>

      <div class="grid grid-cols-3 gap-4">
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Hours (Mon-Fri)</label>
          <input name="hours_weekday" type="text" value="<%= info.hours_weekday || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="7:00 AM - 8:00 PM" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Hours (Saturday)</label>
          <input name="hours_saturday" type="text" value="<%= info.hours_saturday || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="8:00 AM - 6:00 PM" />
        </div>
        <div>
          <label class="block text-sm font-medium text-gray-700 mb-1">Hours (Sunday)</label>
          <input name="hours_sunday" type="text" value="<%= info.hours_sunday || '' %>" class="w-full px-3 py-2 border border-gray-300 rounded-lg" placeholder="9:00 AM - 4:00 PM" />
        </div>
      </div>

      <button type="submit" class="bg-blue-600 text-white px-8 py-3 rounded-lg hover:bg-blue-700 font-medium">Save Contact Info</button>
    </form>
  </div>
</body>
</html>
