<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Analytics</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'analytics' }) %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-8">
      <h1 class="text-2xl font-extrabold text-slate-800">Analytics</h1>
      <p class="text-slate-500 text-sm mt-1">Track your site performance</p>
    </div>

    <!-- Stat Cards -->
    <div id="stat-cards" class="grid grid-cols-1 md:grid-cols-3 gap-5 mb-8">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-blue-500/10 to-transparent rounded-bl-[3rem]"></div>
        <div class="relative flex items-center gap-4">
          <div class="w-12 h-12 bg-gradient-to-br from-blue-500 to-blue-600 rounded-xl flex items-center justify-center shadow-lg shadow-blue-500/25">
            <span class="material-symbols-outlined text-white text-2xl">visibility</span>
          </div>
          <div>
            <p class="text-3xl font-extrabold text-slate-800"><%= totalViews %></p>
            <p class="text-slate-500 text-sm font-medium">Total Page Views</p>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-emerald-500/10 to-transparent rounded-bl-[3rem]"></div>
        <div class="relative flex items-center gap-4">
          <div class="w-12 h-12 bg-gradient-to-br from-emerald-500 to-emerald-600 rounded-xl flex items-center justify-center shadow-lg shadow-emerald-500/25">
            <span class="material-symbols-outlined text-white text-2xl">pages</span>
          </div>
          <div>
            <p class="text-3xl font-extrabold text-slate-800"><%= viewsByPage.length %></p>
            <p class="text-slate-500 text-sm font-medium">Unique Pages</p>
          </div>
        </div>
      </div>
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 relative overflow-hidden">
        <div class="absolute top-0 right-0 w-20 h-20 bg-gradient-to-br from-violet-500/10 to-transparent rounded-bl-[3rem]"></div>
        <div class="relative flex items-center gap-4">
          <div class="w-12 h-12 bg-gradient-to-br from-violet-500 to-violet-600 rounded-xl flex items-center justify-center shadow-lg shadow-violet-500/25">
            <span class="material-symbols-outlined text-white text-2xl">link</span>
          </div>
          <div>
            <p class="text-3xl font-extrabold text-slate-800"><%= topReferrers.length %></p>
            <p class="text-slate-500 text-sm font-medium">Referral Sources</p>
          </div>
        </div>
      </div>
    </div>

    <!-- Daily Views Chart -->
    <div id="daily-chart" class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8 mb-8">
      <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
        <span class="material-symbols-outlined text-cyan-500">show_chart</span> Daily Views (Last 30 Days)
      </h2>
      <canvas id="dailyChart" height="100"></canvas>
    </div>

    <div id="detail-tables" class="grid grid-cols-1 lg:grid-cols-2 gap-6">
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-amber-500">trending_up</span> Top Pages
        </h2>
        <% if (viewsByPage.length === 0) { %>
          <p class="text-slate-500 text-sm">No data yet</p>
        <% } else { %>
          <table class="w-full text-sm">
            <thead class="border-b border-slate-100">
              <tr>
                <th class="text-left py-3 font-bold text-slate-500 text-xs uppercase tracking-wider">Page</th>
                <th class="text-right py-3 font-bold text-slate-500 text-xs uppercase tracking-wider">Views</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% viewsByPage.forEach(p => { %>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="py-3 text-slate-800 font-medium"><%= p._id %></td>
                  <td class="py-3 text-right"><span class="bg-blue-50 text-blue-700 px-2.5 py-1 rounded-lg font-bold text-xs"><%= p.count %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>

      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-8">
        <h2 class="text-lg font-bold text-slate-800 mb-4 flex items-center gap-2">
          <span class="material-symbols-outlined text-violet-500">link</span> Top Referrers
        </h2>
        <% if (topReferrers.length === 0) { %>
          <p class="text-slate-500 text-sm">No referrer data yet</p>
        <% } else { %>
          <table class="w-full text-sm">
            <thead class="border-b border-slate-100">
              <tr>
                <th class="text-left py-3 font-bold text-slate-500 text-xs uppercase tracking-wider">Referrer</th>
                <th class="text-right py-3 font-bold text-slate-500 text-xs uppercase tracking-wider">Views</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-slate-50">
              <% topReferrers.forEach(r => { %>
                <tr class="hover:bg-slate-50 transition-colors">
                  <td class="py-3 text-slate-800 truncate max-w-xs font-medium"><%= r._id %></td>
                  <td class="py-3 text-right"><span class="bg-violet-50 text-violet-700 px-2.5 py-1 rounded-lg font-bold text-xs"><%= r.count %></span></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        <% } %>
      </div>
    </div>
  </div>

  <script>
    const ctx = document.getElementById('dailyChart').getContext('2d');
    const chartData = <%- JSON.stringify(viewsByDay) %>;
    new Chart(ctx, {
      type: 'bar',
      data: {
        labels: chartData.map(d => d._id),
        datasets: [{
          label: 'Page Views',
          data: chartData.map(d => d.count),
          backgroundColor: 'rgba(6, 182, 212, 0.3)',
          borderColor: 'rgba(6, 182, 212, 1)',
          borderWidth: 2,
          borderRadius: 8,
        }],
      },
      options: {
        responsive: true,
        scales: {
          y: { beginAtZero: true, ticks: { stepSize: 1 }, grid: { color: 'rgba(0,0,0,0.05)' } },
          x: { ticks: { maxRotation: 45 }, grid: { display: false } },
        },
        plugins: { legend: { display: false } },
      },
    });
  </script>
  <%
    var tourSteps = [
      { popover: { title: 'Analytics Dashboard', description: 'Track how visitors interact with your website. See page views, popular pages, and where your traffic comes from.' } },
      { element: '#stat-cards', popover: { title: 'Overview Stats', description: 'Quick summary: total page views, number of unique pages visited, and how many different referral sources are sending traffic.' } },
      { element: '#daily-chart', popover: { title: 'Daily Views Chart', description: 'Visual chart showing page views per day over the last 30 days. Helps you spot trends and peak traffic times.' } },
      { element: '#detail-tables', popover: { title: 'Detailed Breakdown', description: 'Left: Top Pages shows which pages get the most visits. Right: Top Referrers shows where your visitors come from (Google, social media, direct, etc.).' } },
      { popover: { title: 'Tips', description: 'Analytics data is collected automatically from every frontend page visit. Check this weekly to understand your audience and optimize content.' } }
    ];
    var tourKey = 'analytics';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
