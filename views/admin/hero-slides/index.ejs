<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Akbik Admin - Hero Slides</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('../partials/nav', { current: 'hero-slides' }) %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-2xl font-bold text-gray-800">Hero Slides</h1>
      <a href="/admin/hero-slides/new" class="bg-blue-600 text-white px-4 py-2 rounded-lg hover:bg-blue-700 text-sm font-medium">+ New Slide</a>
    </div>

    <div class="bg-white rounded-xl shadow-sm border overflow-hidden">
      <table class="w-full">
        <thead class="bg-gray-50 border-b">
          <tr>
            <th class="text-left px-4 py-3 text-sm font-medium text-gray-600">Image</th>
            <th class="text-left px-4 py-3 text-sm font-medium text-gray-600">Headline</th>
            <th class="text-left px-4 py-3 text-sm font-medium text-gray-600">Badge</th>
            <th class="text-left px-4 py-3 text-sm font-medium text-gray-600">Order</th>
            <th class="text-right px-4 py-3 text-sm font-medium text-gray-600">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% slides.forEach(function(slide) { %>
          <tr class="border-b hover:bg-gray-50">
            <td class="px-4 py-3">
              <% if (slide.image_url) { %>
                <img src="<%= slide.image_url %>" class="w-20 h-12 object-cover rounded" />
              <% } else { %>
                <div class="w-20 h-12 bg-gray-200 rounded flex items-center justify-center text-gray-400 text-xs">No image</div>
              <% } %>
            </td>
            <td class="px-4 py-3 text-sm text-gray-800"><%= slide.headline %></td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= slide.badge_text || '-' %></td>
            <td class="px-4 py-3 text-sm text-gray-500"><%= slide.sort_order %></td>
            <td class="px-4 py-3 text-right">
              <a href="/admin/hero-slides/<%= slide._id %>/edit" class="text-blue-600 hover:text-blue-700 text-sm mr-3">Edit</a>
              <form method="POST" action="/admin/hero-slides/<%= slide._id %>/delete" class="inline" onsubmit="return confirm('Delete this slide?')">
                <button type="submit" class="text-red-600 hover:text-red-700 text-sm">Delete</button>
              </form>
            </td>
          </tr>
          <% }); %>
          <% if (slides.length === 0) { %>
          <tr><td colspan="5" class="px-4 py-8 text-center text-gray-400">No slides yet</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</body>
</html>
