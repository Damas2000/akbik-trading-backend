<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Leads</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'leads' }) %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div class="mb-6">
      <h1 class="text-2xl font-extrabold text-slate-800">Leads</h1>
      <p class="text-slate-500 text-sm mt-1">Manage customer leads and inquiries</p>
    </div>

    <!-- Filter Tabs -->
    <div id="filter-tabs" class="flex gap-2 mb-6 flex-wrap">
      <a href="/admin/leads" class="px-4 py-2 rounded-xl text-sm font-semibold transition-all <%= currentStatus === 'all' ? 'bg-gradient-to-r from-slate-700 to-slate-800 text-white shadow-lg' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>">
        All (<%= counts.all %>)
      </a>
      <a href="/admin/leads?status=new" class="px-4 py-2 rounded-xl text-sm font-semibold transition-all <%= currentStatus === 'new' ? 'bg-gradient-to-r from-blue-500 to-blue-600 text-white shadow-lg shadow-blue-500/25' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>">
        New (<%= counts.new %>)
      </a>
      <a href="/admin/leads?status=contacted" class="px-4 py-2 rounded-xl text-sm font-semibold transition-all <%= currentStatus === 'contacted' ? 'bg-gradient-to-r from-amber-500 to-amber-600 text-white shadow-lg shadow-amber-500/25' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>">
        Contacted (<%= counts.contacted %>)
      </a>
      <a href="/admin/leads?status=converted" class="px-4 py-2 rounded-xl text-sm font-semibold transition-all <%= currentStatus === 'converted' ? 'bg-gradient-to-r from-emerald-500 to-emerald-600 text-white shadow-lg shadow-emerald-500/25' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>">
        Converted (<%= counts.converted %>)
      </a>
      <a href="/admin/leads?status=lost" class="px-4 py-2 rounded-xl text-sm font-semibold transition-all <%= currentStatus === 'lost' ? 'bg-gradient-to-r from-red-500 to-red-600 text-white shadow-lg shadow-red-500/25' : 'bg-white border border-slate-200 text-slate-600 hover:bg-slate-50' %>">
        Lost (<%= counts.lost %>)
      </a>
    </div>

    <% if (leads.length === 0) { %>
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-16 text-center">
        <span class="material-symbols-outlined text-6xl text-slate-300 mb-3">people</span>
        <p class="text-slate-500 font-medium">No leads found</p>
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% leads.forEach(lead => { %>
          <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-6 hover:shadow-md transition-all">
            <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <div class="w-10 h-10 bg-gradient-to-br from-orange-400 to-orange-500 rounded-xl flex items-center justify-center text-white font-bold text-sm">
                    <%= lead.first_name ? lead.first_name[0].toUpperCase() : '?' %>
                  </div>
                  <h3 class="font-bold text-slate-800"><%= lead.first_name %> <%= lead.last_name %></h3>
                  <%
                    const badgeStyles = {
                      new: 'bg-blue-100 text-blue-700',
                      contacted: 'bg-amber-100 text-amber-700',
                      converted: 'bg-emerald-100 text-emerald-700',
                      lost: 'bg-red-100 text-red-700'
                    };
                    const badgeStyle = badgeStyles[lead.status] || badgeStyles['new'];
                  %>
                  <span class="text-xs px-3 py-1 rounded-full font-bold <%= badgeStyle %>"><%= lead.status %></span>
                </div>
                <p class="text-sm text-slate-500 mb-1 pl-[52px]"><%= lead.email %></p>
                <p class="text-sm text-slate-500 mb-2 pl-[52px]">Subject: <span class="font-semibold text-slate-700"><%= lead.subject %></span></p>
                <p class="text-sm text-slate-700 pl-[52px]"><%= lead.message %></p>
                <p class="text-xs text-slate-400 mt-2 pl-[52px]"><%= new Date(lead.createdAt).toLocaleString() %></p>
              </div>

              <div class="flex flex-col gap-3 min-w-[200px]">
                <form action="/admin/leads/<%= lead._id %>/status" method="POST" class="flex gap-2">
                  <select name="status" class="border border-slate-200 rounded-xl px-3 py-2 text-sm flex-1 focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500">
                    <option value="new" <%= lead.status === 'new' ? 'selected' : '' %>>New</option>
                    <option value="contacted" <%= lead.status === 'contacted' ? 'selected' : '' %>>Contacted</option>
                    <option value="converted" <%= lead.status === 'converted' ? 'selected' : '' %>>Converted</option>
                    <option value="lost" <%= lead.status === 'lost' ? 'selected' : '' %>>Lost</option>
                  </select>
                  <button type="submit" class="bg-gradient-to-r from-blue-500 to-blue-600 text-white px-4 py-2 rounded-xl text-sm font-semibold hover:from-blue-600 hover:to-blue-700 shadow-sm transition-all">Update</button>
                </form>
              </div>
            </div>

            <details class="mt-4 border-t border-slate-100 pt-4">
              <summary class="text-sm font-semibold text-slate-600 cursor-pointer hover:text-slate-800 flex items-center gap-1">
                <span class="material-symbols-outlined text-base">notes</span>
                Notes <% if (lead.notes) { %><span class="text-blue-500 ml-1">(has notes)</span><% } %>
              </summary>
              <form action="/admin/leads/<%= lead._id %>/notes" method="POST" class="mt-3 flex gap-2">
                <textarea name="notes" rows="2" class="flex-1 border border-slate-200 rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-blue-500/20 focus:border-blue-500"><%= lead.notes || '' %></textarea>
                <button type="submit" class="bg-slate-700 text-white px-5 py-2 rounded-xl text-sm font-semibold hover:bg-slate-800 self-end transition-all">Save</button>
              </form>
            </details>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
  <%
    var tourSteps = [
      { popover: { title: 'Leads Management', description: 'Every contact form submission becomes a lead. Track them through your sales pipeline from initial inquiry to conversion.' } },
      { element: '#filter-tabs', popover: { title: 'Filter by Status', description: 'Filter leads by their current status: New (just submitted), Contacted (you reached out), Converted (became a customer), or Lost (didn\'t convert).' } },
      { popover: { title: 'Lead Actions', description: 'For each lead you can: change its status using the dropdown, and add private notes for your team. Click "Notes" to expand the notes section.' } },
      { popover: { title: 'Tips', description: 'Respond to new leads quickly for best conversion. Use notes to track conversation details. Regularly review "Contacted" leads to follow up.' } }
    ];
    var tourKey = 'leads';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
