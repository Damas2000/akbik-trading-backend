<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Akbik Admin - Leads</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
</head>
<body class="bg-gray-50 min-h-screen">
  <%- include('../partials/nav', { current: 'leads' }) %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <h1 class="text-3xl font-bold text-gray-800 mb-6">Leads</h1>

    <!-- Filter Tabs -->
    <div class="flex gap-2 mb-6 flex-wrap">
      <a href="/admin/leads" class="px-4 py-2 rounded-lg text-sm font-medium <%= currentStatus === 'all' ? 'bg-blue-600 text-white' : 'bg-white border text-gray-600 hover:bg-gray-50' %>">
        All (<%= counts.all %>)
      </a>
      <a href="/admin/leads?status=new" class="px-4 py-2 rounded-lg text-sm font-medium <%= currentStatus === 'new' ? 'bg-blue-600 text-white' : 'bg-white border text-gray-600 hover:bg-gray-50' %>">
        New (<%= counts.new %>)
      </a>
      <a href="/admin/leads?status=contacted" class="px-4 py-2 rounded-lg text-sm font-medium <%= currentStatus === 'contacted' ? 'bg-yellow-500 text-white' : 'bg-white border text-gray-600 hover:bg-gray-50' %>">
        Contacted (<%= counts.contacted %>)
      </a>
      <a href="/admin/leads?status=converted" class="px-4 py-2 rounded-lg text-sm font-medium <%= currentStatus === 'converted' ? 'bg-green-600 text-white' : 'bg-white border text-gray-600 hover:bg-gray-50' %>">
        Converted (<%= counts.converted %>)
      </a>
      <a href="/admin/leads?status=lost" class="px-4 py-2 rounded-lg text-sm font-medium <%= currentStatus === 'lost' ? 'bg-red-600 text-white' : 'bg-white border text-gray-600 hover:bg-gray-50' %>">
        Lost (<%= counts.lost %>)
      </a>
    </div>

    <% if (leads.length === 0) { %>
      <div class="bg-white rounded-xl shadow-sm border p-12 text-center">
        <span class="material-symbols-outlined text-6xl text-gray-300 mb-4">person_search</span>
        <p class="text-gray-500">No leads found</p>
      </div>
    <% } else { %>
      <div class="space-y-4">
        <% leads.forEach(lead => { %>
          <div class="bg-white rounded-xl shadow-sm border p-6">
            <div class="flex flex-col md:flex-row md:items-start justify-between gap-4">
              <div class="flex-1">
                <div class="flex items-center gap-3 mb-2">
                  <h3 class="font-bold text-gray-800"><%= lead.first_name %> <%= lead.last_name %></h3>
                  <%
                    const badgeColors = { new: 'bg-blue-100 text-blue-700', contacted: 'bg-yellow-100 text-yellow-700', converted: 'bg-green-100 text-green-700', lost: 'bg-red-100 text-red-700' };
                    const badgeColor = badgeColors[lead.status] || badgeColors['new'];
                  %>
                  <span class="text-xs px-2 py-1 rounded-full font-medium <%= badgeColor %>"><%= lead.status %></span>
                </div>
                <p class="text-sm text-gray-500 mb-1"><%= lead.email %></p>
                <p class="text-sm text-gray-500 mb-2">Subject: <%= lead.subject %></p>
                <p class="text-sm text-gray-700"><%= lead.message %></p>
                <p class="text-xs text-gray-400 mt-2"><%= new Date(lead.createdAt).toLocaleString() %></p>
              </div>

              <div class="flex flex-col gap-3 min-w-[200px]">
                <!-- Status Change -->
                <form action="/admin/leads/<%= lead._id %>/status" method="POST" class="flex gap-2">
                  <select name="status" class="border rounded-lg px-2 py-1 text-sm flex-1">
                    <option value="new" <%= lead.status === 'new' ? 'selected' : '' %>>New</option>
                    <option value="contacted" <%= lead.status === 'contacted' ? 'selected' : '' %>>Contacted</option>
                    <option value="converted" <%= lead.status === 'converted' ? 'selected' : '' %>>Converted</option>
                    <option value="lost" <%= lead.status === 'lost' ? 'selected' : '' %>>Lost</option>
                  </select>
                  <button type="submit" class="bg-blue-600 text-white px-3 py-1 rounded-lg text-sm hover:bg-blue-700">Update</button>
                </form>
              </div>
            </div>

            <!-- Notes -->
            <details class="mt-4 border-t pt-4">
              <summary class="text-sm font-medium text-gray-600 cursor-pointer hover:text-gray-800">
                Notes <% if (lead.notes) { %><span class="text-blue-500">(has notes)</span><% } %>
              </summary>
              <form action="/admin/leads/<%= lead._id %>/notes" method="POST" class="mt-3 flex gap-2">
                <textarea name="notes" rows="2" class="flex-1 border rounded-lg px-3 py-2 text-sm"><%= lead.notes || '' %></textarea>
                <button type="submit" class="bg-gray-600 text-white px-4 py-2 rounded-lg text-sm hover:bg-gray-700 self-end">Save</button>
              </form>
            </details>
          </div>
        <% }) %>
      </div>
    <% } %>
  </div>
</body>
</html>
