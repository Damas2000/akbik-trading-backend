<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin - Newsletter</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800;900&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined" />
  <style>body{font-family:'Inter',sans-serif}</style>
</head>
<body class="bg-slate-100 min-h-screen">
  <%- include('../partials/nav', { current: 'newsletter' }) %>

  <div class="max-w-7xl mx-auto px-4 py-8">
    <div id="page-header" class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-extrabold text-slate-800">Newsletter Subscribers</h1>
        <p class="text-slate-500 text-sm mt-1"><%= subscribers.filter(s => s.is_active).length %> active / <%= subscribers.length %> total</p>
      </div>
      <a id="export-btn" href="/api/newsletter/export" class="flex items-center gap-2 bg-gradient-to-r from-emerald-500 to-emerald-600 text-white px-5 py-2.5 rounded-xl text-sm font-semibold hover:from-emerald-600 hover:to-emerald-700 shadow-lg shadow-emerald-500/25 transition-all">
        <span class="material-symbols-outlined text-lg">download</span> Export CSV
      </a>
    </div>

    <% if (subscribers.length === 0) { %>
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 p-16 text-center">
        <span class="material-symbols-outlined text-6xl text-slate-300 mb-3">mail</span>
        <p class="text-slate-500 font-medium">No subscribers yet</p>
      </div>
    <% } else { %>
      <div class="bg-white rounded-2xl shadow-sm border border-slate-200 overflow-hidden">
        <table class="w-full text-sm">
          <thead class="bg-gradient-to-r from-slate-50 to-slate-100 border-b border-slate-200">
            <tr>
              <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Email</th>
              <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Subscribed</th>
              <th class="text-left px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Status</th>
              <th class="text-right px-6 py-4 text-xs font-bold text-slate-500 uppercase tracking-wider">Actions</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-slate-100">
            <% subscribers.forEach(sub => { %>
              <tr class="hover:bg-pink-50/50 transition-colors">
                <td class="px-6 py-4 font-semibold text-slate-800"><%= sub.email %></td>
                <td class="px-6 py-4 text-slate-500"><%= new Date(sub.subscribed_at).toLocaleDateString() %></td>
                <td class="px-6 py-4">
                  <% if (sub.is_active) { %>
                    <span class="bg-emerald-100 text-emerald-700 text-xs px-3 py-1 rounded-full font-bold">Active</span>
                  <% } else { %>
                    <span class="bg-slate-100 text-slate-500 text-xs px-3 py-1 rounded-full font-bold">Unsubscribed</span>
                  <% } %>
                </td>
                <td class="px-6 py-4 text-right">
                  <% if (sub.is_active) { %>
                    <form action="/admin/newsletter/<%= sub._id %>/unsubscribe" method="POST" class="inline" onsubmit="return confirm('Unsubscribe this email?')">
                      <button class="text-red-500 hover:text-red-700 text-xs font-bold">Unsubscribe</button>
                    </form>
                  <% } %>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
  <%
    var tourSteps = [
      { element: '#page-header', popover: { title: 'Newsletter Subscribers', description: 'View all email subscribers who signed up through your website\'s newsletter form. Active vs total count is shown below the title.' } },
      { element: '#export-btn', popover: { title: 'Export CSV', description: 'Download all subscriber emails as a CSV file. Useful for importing into email marketing tools like Mailchimp or SendGrid.' } },
      { popover: { title: 'Tips', description: 'The newsletter form appears in the footer and CTA section of your site. You can unsubscribe individual users from here if needed.' } }
    ];
    var tourKey = 'newsletter';
  %>
  <%- include('../partials/tour', { tourSteps: tourSteps, tourKey: tourKey }) %>
</body>
</html>
